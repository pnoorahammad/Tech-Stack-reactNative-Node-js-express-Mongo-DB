PORT=5000
NODE_ENV=development
# For local MongoDB:
# MONGODB_URI=mongodb://localhost:27017/expert-booking
# For MongoDB Atlas (replace with your Atlas connection string):
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/expert-booking?retryWrites=true&w=majority
CORS_ORIGIN=http://localhost:3000
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
